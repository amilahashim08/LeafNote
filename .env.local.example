# .env.local.example - copy to .env.local and fill values

# Local (preferred for quick local dev)
MONGODB_URI=mongodb://127.0.0.1:27017/leafnote

# OR MongoDB Atlas - replace <user> and <password> and remove angle brackets
# If your password has special characters (e.g. @, #, /, ?), URL-encode it:
# const encoded = encodeURIComponent('p@ss#word');
# Example:
# MONGODB_URI=mongodb+srv://<user>:<encodedPassword>@cluster0.dbvgvxv.mongodb.net/leafnote?retryWrites=true&w=majority

JWT_SECRET=your-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000
